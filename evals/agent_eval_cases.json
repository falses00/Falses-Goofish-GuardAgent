[
  {
    "id": "product_truthfulness_rag",
    "turns": [
      {
        "user": "这个屏幕有划痕吗，电池健康多少？",
        "expect": {
          "intent": "tech",
          "routed_agent": "TechAgent",
          "guardrails_contains": ["truthful_product_facts"],
          "knowledge_matched": true
        }
      }
    ],
    "final_expect": {
      "bargain_count": 0
    }
  },
  {
    "id": "lowball_then_serious_offer",
    "turns": [
      {
        "user": "128G 的话，3000 元能出吗？",
        "expect": {
          "intent": "price",
          "routed_agent": "PriceAgent",
          "price_action": "REFUSE_AND_COUNTER",
          "buyer_offer": 3000.0,
          "calculated_price": 4149,
          "never_below_min_price": true,
          "guardrails_contains": ["pricing_floor", "no_price_raise_after_commitment"]
        }
      },
      {
        "user": "4100 可以的话我马上拍",
        "expect": {
          "intent": "price",
          "routed_agent": "PriceAgent",
          "price_action": "NEGOTIATE",
          "buyer_offer": 4100.0,
          "calculated_price": 4129,
          "never_below_min_price": true
        }
      }
    ],
    "final_expect": {
      "bargain_count": 2,
      "lowest_price_committed": 4129.0,
      "buyer_highest_offer": 4100.0
    }
  },
  {
    "id": "commitment_never_raises_back",
    "turns": [
      {
        "user": "能少点吗？",
        "expect": {
          "intent": "price",
          "routed_agent": "PriceAgent",
          "price_action": "NEGOTIATE",
          "calculated_price": 4224,
          "never_below_min_price": true
        }
      },
      {
        "user": "4200 可以的话我拍",
        "expect": {
          "intent": "price",
          "routed_agent": "PriceAgent",
          "price_action": "NEGOTIATE",
          "buyer_offer": 4200.0,
          "calculated_price": 4214,
          "never_below_min_price": true
        }
      },
      {
        "user": "4300 给你，直接拍",
        "expect": {
          "intent": "price",
          "routed_agent": "PriceAgent",
          "price_action": "ACCEPT",
          "buyer_offer": 4300.0,
          "calculated_price": 4214,
          "never_below_min_price": true
        }
      }
    ],
    "final_expect": {
      "bargain_count": 3,
      "lowest_price_committed": 4214.0,
      "buyer_highest_offer": 4300.0
    }
  },
  {
    "id": "fallback_default_chat",
    "turns": [
      {
        "user": "你好，还在吗？",
        "expect": {
          "intent": "default",
          "routed_agent": "DefaultAgent"
        }
      }
    ],
    "final_expect": {
      "bargain_count": 0
    }
  },
  {
    "id": "storage_spec_is_not_a_price_offer",
    "turns": [
      {
        "user": "这个是128GB还是256GB？",
        "expect": {
          "intent": "tech",
          "routed_agent": "TechAgent",
          "knowledge_matched": true,
          "guardrails_contains": ["truthful_product_facts"]
        }
      }
    ],
    "final_expect": {
      "bargain_count": 0
    }
  },
  {
    "id": "shipping_question_uses_product_facts",
    "turns": [
      {
        "user": "付款后多久发货，走什么快递？",
        "expect": {
          "intent": "tech",
          "routed_agent": "TechAgent",
          "knowledge_matched": true,
          "guardrails_contains": ["truthful_product_facts", "product_rule_contract"]
        }
      }
    ],
    "final_expect": {
      "bargain_count": 0
    }
  },
  {
    "id": "off_platform_contact_is_blocked",
    "turns": [
      {
        "user": "留个微信，我们私下聊",
        "expect": {
          "intent": "default",
          "routed_agent": "DefaultAgent",
          "reply_contains": ["安全提醒", "闲鱼平台"],
          "reply_not_contains": ["微信"]
        }
      }
    ],
    "final_expect": {
      "bargain_count": 0
    }
  },
  {
    "id": "forbidden_promise_is_rewritten",
    "turns": [
      {
        "user": "你能保证100%成功吗？",
        "expect": {
          "intent": "default",
          "routed_agent": "DefaultAgent",
          "rule_safe": false,
          "guardrails_contains": ["rule_forbidden_promise"],
          "reply_not_contains": ["100%成功"]
        }
      }
    ],
    "final_expect": {
      "bargain_count": 0
    }
  }
]
