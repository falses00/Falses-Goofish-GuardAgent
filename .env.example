MODEL_PROVIDER=agnes
AGNES_API_KEY=your_agnes_api_key_here
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
AGNES_MODEL_NAME=agnes-2.0-flash
# 兼容其它 OpenAI-compatible provider 时可改用以下通用变量
# API_KEY=your_api_key_here
# MODEL_BASE_URL=https://api.example.com/v1
# MODEL_NAME=your-model-name
COOKIES_STR=your_cookies_here
# 容器/服务环境设为 true，配置缺失时直接失败，避免等待终端输入
NON_INTERACTIVE=false
TOGGLE_KEYWORDS=。
SIMULATE_HUMAN_TYPING=False

# ==================== Falses Goofish GuardAgent 业务参数 ====================
# 允许的最大折扣限制（如 0.85 表示最多打 8.5 折，底线之下的出价会被强制拒绝）
DEFAULT_DISCOUNT_LIMIT=0.85
# 日志级别配置（DEBUG/INFO/WARNING/ERROR）
LOG_LEVEL=INFO
# SQLite 记忆数据库路径
CHAT_DB_PATH=data/chat_history.db
# 商品规则中心路径：控制承诺边界、售后边界和发货条件
PRODUCT_RULES_PATH=data/product_rules.json
# 真人卖家回复风格配置：控制客服腔、机器腔、回复长度和口语化改写
HUMAN_REPLY_STYLE_PATH=data/human_reply_style.json
# 自动回复执行 Outbox：真实发送前先落库，防止重连或重复同步导致重复回复
REPLY_OUTBOX_DB_PATH=data/reply_outbox.db
# 安全默认值：只记录 Outbox，不真实调用闲鱼发送；验证完成后才显式改为 false
REPLY_SEND_DRY_RUN=true
# sending 状态超过该时间后允许重新抢占，防止进程崩溃造成永久卡单
REPLY_SEND_CLAIM_TIMEOUT_SECONDS=300
# 闲鱼 HTTP 调用的超时与有限重试；网络暂态故障不会被误判为 Cookie 失效
XIANYU_HTTP_TIMEOUT_SECONDS=20
XIANYU_HTTP_RETRY_DELAY_SECONDS=0.5
XIANYU_LOGIN_CHECK_MAX_ATTEMPTS=2
XIANYU_TOKEN_MAX_ATTEMPTS=2
# 连续买家消息聚合：短时间内多条消息只触发一次 Agent 决策
MESSAGE_AGGREGATION_ENABLED=true
MESSAGE_AGGREGATION_WINDOW_SECONDS=1.2
MESSAGE_AGGREGATION_MAX_MESSAGES=5
MESSAGE_AGGREGATION_MAX_CHARS=1200
# FastAPI 服务离线演示模式；未配置 API_KEY 时会自动使用离线 deterministic LLM
API_OFFLINE_MODE=false
# FastAPI 服务独立会话数据库路径
API_CHAT_DB_PATH=data/api_chat_history.db
# FastAPI 服务 trace JSONL 路径
AGENT_TRACE_PATH=logs/agent_traces.jsonl
